#!/bin/bash

# Pre-push hook: run the same checks executed in CI before pushing.
# To skip this hook, use: git push --no-verify

set -euo pipefail

echo "Running pre-push CI checks..."

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

echo ""
echo "=== CI unit checks ==="
make ci-unit

if [ "${RUN_E2E:-0}" = "1" ]; then
    cleanup() {
        echo ""
        echo "=== Cleaning E2E containers ==="
        make e2e-down >/dev/null 2>&1 || true
    }
    trap cleanup EXIT

    echo ""
    echo "=== Preparing E2E dependencies ==="
    make e2e-prepare-ci

    echo ""
    echo "=== CI end-to-end checks ==="
    make ci-e2e
else
    echo ""
    echo "Skipping E2E tests (set RUN_E2E=1 to enable)."
fi

echo ""
echo "✅ Pre-push checks passed. Proceeding with push..."
