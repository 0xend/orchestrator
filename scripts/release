#!/usr/bin/env bash
set -euo pipefail

# Release script: creates a GitHub release and deploys to Heroku
#
# Usage:
#   ./scripts/release                  # Auto-increment patch (v1.3.0 → v1.3.1)
#   ./scripts/release patch            # Same as above
#   ./scripts/release minor            # Auto-increment minor (v1.3.0 → v1.4.0)
#   ./scripts/release major            # Auto-increment major (v1.3.0 → v2.0.0)
#   ./scripts/release v1.5.0           # Explicit version

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

info()  { echo -e "${BLUE}==>${NC} $1"; }
ok()    { echo -e "${GREEN}==>${NC} $1"; }
warn()  { echo -e "${YELLOW}==>${NC} $1"; }
error() { echo -e "${RED}==>${NC} $1" >&2; }

# --- Pre-flight checks ---

if ! command -v gh &>/dev/null; then
    error "GitHub CLI (gh) is required. Install: brew install gh"
    exit 1
fi

if ! git diff --quiet || ! git diff --cached --quiet; then
    error "Working tree is dirty. Commit or stash changes before releasing."
    exit 1
fi

CURRENT_BRANCH=$(git branch --show-current)
if [ "$CURRENT_BRANCH" != "main" ]; then
    error "Releases must be created from the main branch (currently on: $CURRENT_BRANCH)"
    exit 1
fi

info "Pulling latest from origin/main..."
git pull --ff-only origin main

# --- Determine version ---

LATEST_TAG=$(git tag --sort=-v:refname | head -1)
if [ -z "$LATEST_TAG" ]; then
    LATEST_TAG="v0.0.0"
fi

# Strip leading 'v' for arithmetic
LATEST="${LATEST_TAG#v}"
IFS='.' read -r MAJOR MINOR PATCH <<< "$LATEST"

BUMP="${1:-patch}"

case "$BUMP" in
    patch)
        PATCH=$((PATCH + 1))
        VERSION="v${MAJOR}.${MINOR}.${PATCH}"
        ;;
    minor)
        MINOR=$((MINOR + 1))
        PATCH=0
        VERSION="v${MAJOR}.${MINOR}.0"
        ;;
    major)
        MAJOR=$((MAJOR + 1))
        MINOR=0
        PATCH=0
        VERSION="v${MAJOR}.0.0"
        ;;
    v*.*.*)
        VERSION="$BUMP"
        ;;
    *)
        error "Invalid version bump: $BUMP"
        echo "Usage: $0 [patch|minor|major|vX.Y.Z]"
        exit 1
        ;;
esac

if git tag | grep -q "^${VERSION}$"; then
    error "Tag ${VERSION} already exists"
    exit 1
fi

# --- Generate release notes ---

info "Changes since ${LATEST_TAG}:"
echo ""
NOTES=$(git log "${LATEST_TAG}..HEAD" --pretty=format:"- %s" --no-merges)
if [ -z "$NOTES" ]; then
    warn "No commits since ${LATEST_TAG}"
    NOTES="- Maintenance release"
fi
echo "$NOTES"
echo ""

# --- Confirm ---

echo -e "${YELLOW}Ready to release ${VERSION}${NC}"
echo "  1. Create git tag ${VERSION}"
echo "  2. Create GitHub release"
echo "  3. Deploy backend to Heroku (migrations run automatically)"
echo "  4. Deploy frontend to Heroku"
echo ""
read -p "Proceed? [y/N] " -n 1 -r
echo ""
if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    warn "Aborted."
    exit 0
fi

# --- Create tag and GitHub release ---

info "Creating tag ${VERSION}..."
git tag -a "${VERSION}" -m "Release ${VERSION}"

info "Pushing tag to origin..."
git push origin "${VERSION}"

info "Creating GitHub release..."
gh release create "${VERSION}" \
    --title "${VERSION}" \
    --notes "${NOTES}" \
    --latest

ok "GitHub release ${VERSION} created"

# --- Deploy backend ---

info "Deploying backend to Heroku..."
if git subtree push --prefix backend heroku-backend main; then
    ok "Backend deployed (migrations will run during release phase)"
else
    # subtree push fails if there are no new changes to push
    warn "Backend subtree push returned non-zero (may already be up to date)"
    warn "Force-pushing backend..."
    git push heroku-backend "$(git subtree split --prefix backend main)":refs/heads/main --force
    ok "Backend force-pushed"
fi

# --- Deploy frontend ---

info "Deploying frontend to Heroku..."
if git subtree push --prefix frontend heroku-frontend main; then
    ok "Frontend deployed"
else
    warn "Frontend subtree push returned non-zero (may already be up to date)"
    warn "Force-pushing frontend..."
    git push heroku-frontend "$(git subtree split --prefix frontend main)":refs/heads/main --force
    ok "Frontend force-pushed"
fi

# --- Done ---

echo ""
ok "Release ${VERSION} complete!"
echo ""
echo "  GitHub:   $(gh release view "${VERSION}" --json url -q .url)"
echo "  Backend:  https://elsabor-api.herokuapp.com/api/v1/health"
echo "  Frontend: https://elsabor-web.herokuapp.com"
